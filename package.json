{
  "name": "flixon-app",
  "version": "2.4.0",
  "description": "FlixOn — plataforma premium de streaming de filmes, séries e animes (Desktop / Windows)",
  "author": "FlixOn",
  "license": "MIT",
  "main": "electron/main.js",
  "scripts": {
    "vite": "vite",
    "dev": "concurrently -k -n VITE,ELECTRON -c green,blue \"vite\" \"wait-on http://localhost:5173 && cross-env VITE_DEV_SERVER_URL=http://localhost:5173 electron .\"",
    "build": "vite build",
    "start": "electron .",
    "dist": "vite build && electron-builder",
    "dist:win": "vite build && electron-builder --win",
    "cap:sync": "vite build && npx cap sync android",
    "cap:open": "npx cap open android",
    "apk:debug": "vite build && npx cap sync android && cd android && ./gradlew assembleDebug",
    "apk:release": "vite build && npx cap sync android && cd android && ./gradlew assembleRelease"
  },
  "dependencies": {
    "@capacitor/android": "^6.2.1",
    "@capacitor/core": "^6.2.1",
    "@supabase/supabase-js": "^2.109.0",
    "hls.js": "^1.6.16",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.24.0"
  },
  "devDependencies": {
    "@capacitor/cli": "^6.2.1",
    "@vitejs/plugin-legacy": "^5.4.3",
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.19",
    "concurrently": "^8.2.2",
    "cross-env": "^7.0.3",
    "electron": "^30.1.0",
    "electron-builder": "^24.13.3",
    "postcss": "^8.4.38",
    "tailwindcss": "^3.4.4",
    "terser": "^5.48.0",
    "vite": "^5.3.1",
    "wait-on": "^7.2.0"
  },
  "build": {
    "appId": "com.flixon.app",
    "productName": "FlixOn",
    "files": [
      "dist/**/*",
      "electron/**/*"
    ],
    "directories": {
      "output": "release",
      "buildResources": "public"
    },
    "win": {
      "target": [
        "nsis"
      ],
      "icon": "public/icon.png"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "FlixOn"
    }
  }
}
